{
  "name": "time_manager",
  "version": "1.0.0",
  "description": "本地时间与时区工具包。",
  "author": "Serana Team",
  "format": "sebastian_package",
  "runtime": "python",
  "instruction_file": "SKILL.md",
  "entrypoint": "__init__.py",
  "agent_type": "all",
  "max_instances": 5,
  "tools": [
    {
      "name": "get_current_time",
      "description": "获取指定时区的当前时间。",
      "input_schema": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string",
            "description": "IANA 时区名称。",
            "default": "Asia/Shanghai"
          },
          "format": {
            "type": "string",
            "description": "输出格式。",
            "enum": ["full", "date", "time", "iso"],
            "default": "full"
          }
        }
      }
    },
    {
      "name": "convert_timezone",
      "description": "将时间字符串转换到另一个时区。",
      "input_schema": {
        "type": "object",
        "properties": {
          "source_time": {
            "type": "string",
            "description": "原始时间字符串。"
          },
          "source_tz": {
            "type": "string",
            "description": "当时间字符串不带时区时使用的源时区。"
          },
          "target_tz": {
            "type": "string",
            "description": "目标时区。"
          }
        },
        "required": ["source_time", "target_tz"]
      }
    },
    {
      "name": "calculate_duration",
      "description": "计算两个时间之间的时长。",
      "input_schema": {
        "type": "object",
        "properties": {
          "start_time": {
            "type": "string",
            "description": "开始时间。"
          },
          "end_time": {
            "type": "string",
            "description": "结束时间。"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_day_info",
      "description": "获取指定日期的日历信息。",
      "input_schema": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "YYYY-MM-DD 格式的日期。"
          }
        }
      }
    }
  ]
}
