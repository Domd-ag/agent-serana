{
  "name": "weather",
  "version": "1.0.0",
  "description": "天气技能包，可获取实时天气与短期预报。",
  "author": "Peter Steinberger / Serana Team",
  "format": "sebastian_package",
  "runtime": "python",
  "instruction_file": "SKILL.md",
  "entrypoint": "__init__.py",
  "registry_slug": "weather",
  "source_url": "https://clawhub.ai/steipete/weather",
  "agent_type": "all",
  "max_instances": 5,
  "tools": [
    {
      "name": "get_current_weather",
      "description": "获取指定地点的当前天气。",
      "input_schema": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string",
            "description": "城市名、机场代码或地点名称。"
          },
          "units": {
            "type": "string",
            "description": "单位制。",
            "enum": ["metric", "us"],
            "default": "metric"
          }
        },
        "required": ["location"]
      }
    },
    {
      "name": "get_forecast",
      "description": "获取指定地点的短期天气预报。",
      "input_schema": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string",
            "description": "城市名、机场代码或地点名称。"
          },
          "days": {
            "type": "integer",
            "description": "要汇总的预报天数。",
            "default": 1
          },
          "units": {
            "type": "string",
            "description": "单位制。",
            "enum": ["metric", "us"],
            "default": "metric"
          }
        },
        "required": ["location"]
      }
    }
  ]
}
