{
  "name": "memory_manager",
  "version": "1.1.0",
  "description": "管理用户的长期记忆与临时工作记忆，支持保存、搜索和清空。",
  "author": "Serana Team",
  "format": "sebastian_package",
  "runtime": "python",
  "instruction_file": "SKILL.md",
  "entrypoint": "__init__.py",
  "agent_type": "all",
  "max_instances": 3,
  "tools": [
    {
      "name": "memory_save",
      "description": "保存一条用户长期记忆。",
      "input_schema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "记忆键名，例如 preferred_drink" },
          "value": { "type": "string", "description": "记忆内容，例如 黑咖啡" },
          "category": { "type": "string", "description": "可选分类，例如 preference" }
        },
        "required": ["key", "value"]
      }
    },
    {
      "name": "memory_search",
      "description": "搜索与当前问题相关的长期记忆和历史线索。",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "要搜索的内容，例如 我喜欢什么饮料" },
          "limit": { "type": "integer", "description": "最多返回多少条结果", "default": 5 }
        },
        "required": ["query"]
      }
    },
    {
      "name": "working_memory_save",
      "description": "把当前对话或当前目标的临时工作信息先记下来，不写入长期记忆。",
      "input_schema": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "description": "临时记忆键名，例如 trip_budget" },
          "value": { "type": "string", "description": "临时记忆内容，例如 预算上限 500 元" },
          "scope": { "type": "string", "description": "作用域：conversation 或 goal", "default": "conversation" },
          "session_id": { "type": "string", "description": "当前对话 ID，可选" },
          "goal_id": { "type": "string", "description": "当前目标 ID，可选" }
        },
        "required": ["key", "value"]
      }
    },
    {
      "name": "working_memory_clear",
      "description": "清空当前对话或当前目标的临时工作记忆。",
      "input_schema": {
        "type": "object",
        "properties": {
          "scope": { "type": "string", "description": "作用域：conversation 或 goal", "default": "conversation" },
          "session_id": { "type": "string", "description": "当前对话 ID，可选" },
          "goal_id": { "type": "string", "description": "当前目标 ID，可选" }
        }
      }
    }
  ]
}
