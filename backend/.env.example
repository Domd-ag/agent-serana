# Serana 后端本地配置示例

APP_NAME=Serana Backend
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO
SQL_ECHO=false
CORS_ALLOW_ORIGINS=*

DATABASE_URL=sqlite+aiosqlite:///./serana.db

SECRET_KEY=dev-secret-key-change-in-production
ENCRYPTION_KEY=dev-encryption-key-32bytes!!
ALGORITHM=HS256

HOST=0.0.0.0
PORT=8000

CLAWHUB_BASE_URL=https://clawhub.ai
